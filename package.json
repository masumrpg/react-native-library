{
  "name": "react-native-library",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:native": "turbo dev --filter='@masumdev/*' --filter=native",
    "gen:expo-package": "bunx turbo gen expo-package",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@turbo/gen": "^2.9.8",
    "prettier": "^3.1.1",
    "turbo": "^2.10.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "react-native-parsed-text": "^0.0.22"
  }
}
